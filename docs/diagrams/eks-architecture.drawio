                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="600" y="330" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="svc_sub" value="webhook-handler&#xa;ClusterIP : 8080&#xa;Stable in-cluster DNS"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=10;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="600" y="372" width="180" height="45" as="geometry"/>
    </mxCell>

    <!-- ──────────────────────────────────────────────────────────────
         Deployment
    ────────────────────────────────────────────────────────────────── -->
    <mxCell id="deploy_box" value="Webhook Handler"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#d5e8d4;strokeColor=#82b366;
                   verticalAlign=top;align=center;
                   fontSize=11;fontStyle=1;dashed=0;arcSize=5;"
            vertex="1" parent="1">
      <mxGeometry x="840" y="220" width="380" height="340" as="geometry"/>
    </mxCell>
    <mxCell id="deploy" value="🚀  Deployment  (2 replicas)"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#d5e8d4;strokeColor=#82b366;
                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="860" y="270" width="340" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="deploy_sub"
            value="Image: pr-reviewer-webhook:latest&#xa;&#xa;① Verify GitHub HMAC signature&#xa;② Filter: opened / synchronize / reopened&#xa;③ Build DNS-safe Job name&#xa;    pr-review-{repo}-{pr}-{unix-ts}&#xa;④ kubernetes-client.BatchV1Api&#xa;    → create_namespaced_job()"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;
                   spacingLeft=8;"
            vertex="1" parent="1">
      <mxGeometry x="860" y="314" width="340" height="150" as="geometry"/>
    </mxCell>
    <mxCell id="sa" value="👤  ServiceAccount: webhook-handler"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#e3f2fd;strokeColor=#1565c0;
                   fontSize=10;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="860" y="475" width="340" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="sa_sub"
            value="Role → batch/v1 jobs: create · get · list  (pr-reviewer ns only)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=9;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="860" y="507" width="340" height="20" as="geometry"/>
    </mxCell>

    <!-- ──────────────────────────────────────────────────────────────
         Secrets
    ────────────────────────────────────────────────────────────────── -->
    <mxCell id="secrets_box" value="Secrets"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#fff8e1;strokeColor=#f9a825;
                   verticalAlign=top;align=center;
                   fontSize=11;fontStyle=1;dashed=0;arcSize=5;"
            vertex="1" parent="1">
      <mxGeometry x="1290" y="220" width="420" height="340" as="geometry"/>
    </mxCell>
    <mxCell id="sec_r" value="🔐  pr-reviewer-secrets"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#ffe6cc;strokeColor=#d79b00;
                   fontSize=11;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="1310" y="270" width="380" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="sec_r_sub"
            value="ANTHROPIC_API_KEY  (sk-ant-…)&#xa;GITHUB_TOKEN  (ghp_…)&#xa;PR_REVIEWER_MODEL  (optional)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=10;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="1310" y="308" width="380" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="sec_w" value="🔐  webhook-secrets"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#ffe6cc;strokeColor=#d79b00;
                   fontSize=11;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="1310" y="390" width="380" height="35" as="geometry"/>
    </mxCell>
    <mxCell id="sec_w_sub"
            value="WEBHOOK_SECRET  (GitHub HMAC key)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=10;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="1310" y="428" width="380" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="sec_note"
            value="⚠️  Never logged. Consider External Secrets Operator&#xa;or Sealed Secrets for production key rotation."
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=9;
                   fontColor=#b85450;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="1310" y="470" width="380" height="55" as="geometry"/>
    </mxCell>

    <!-- ──────────────────────────────────────────────────────────────
         K8s Job
    ────────────────────────────────────────────────────────────────── -->
    <mxCell id="job" value="⚙️  K8s Job  (ephemeral — one per PR event)"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#f8cecc;strokeColor=#b85450;
                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="840" y="680" width="870" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="job_sub"
            value="Name:      pr-review-{repo-slug}-{pr-number}-{unix-timestamp}&#xa;Image:     pr-reviewer : latest  (from ECR)&#xa;Command:   pr-reviewer review --url $PR_URL&#xa;&#xa;Resources: CPU 100 m → 500 m  ·  RAM 256 Mi → 512 Mi&#xa;Policy:    restartPolicy: Never  ·  backoffLimit: 1&#xa;Cleanup:   ttlSecondsAfterFinished: 3600  (auto-deleted 1 h after completion)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;
                   spacingLeft=12;"
            vertex="1" parent="1">
      <mxGeometry x="840" y="724" width="870" height="110" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════
         ARROWS — Primary flow (solid, blue)
    ══════════════════════════════════════════════════════════════════ -->

    <!-- GitHub → ALB -->
    <mxCell id="e1" value="POST /webhook&#xa;X-Hub-Signature-256&#xa;X-GitHub-Event: pull_request"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#1565c0;strokeWidth=2;
                   fontColor=#1565c0;fontSize=9;
                   entryX=0;entryY=0.5;entryDx=0;entryDy=0;
                   exitX=1;exitY=0.5;exitDx=0;exitDy=0;"
            edge="1" source="gh_src" target="alb" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="270" y="170"/>
          <mxPoint x="270" y="390"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ALB → Service -->
    <mxCell id="e2" value="HTTPS → HTTP&#xa;port 8080"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#1565c0;strokeWidth=2;
                   fontColor=#1565c0;fontSize=9;
                   exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="alb" target="svc" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Service → Deployment -->
    <mxCell id="e3" value="route to pod"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#388e3c;strokeWidth=2;
                   fontColor=#388e3c;fontSize=9;
                   exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="svc" target="deploy" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="820" y="350"/>
          <mxPoint x="820" y="290"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Deployment → Job (create) -->
    <mxCell id="e4" value="BatchV1Api&#xa;create_namespaced_job()"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#b85450;strokeWidth=2.5;
                   fontColor=#b85450;fontSize=9;fontStyle=1;
                   exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                   entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
            edge="1" source="deploy_box" target="job" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Job → Anthropic API -->
    <mxCell id="e5" value="AI analysis&#xa;multi-turn tool calls"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#7b1fa2;strokeWidth=2;
                   fontColor=#7b1fa2;fontSize=9;
                   exitX=0;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="job" target="ant" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="730" y="700"/>
          <mxPoint x="730" y="440"/>
          <mxPoint x="270" y="440"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Job → GitHub API (post comments) -->
    <mxCell id="e6" value="4 API calls:&#xa;① HEAD SHA&#xa;② diff → position map&#xa;③ batch inline comments&#xa;④ summary comment"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#1565c0;strokeWidth=2;
                   fontColor=#1565c0;fontSize=9;
                   exitX=0;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="job" target="gh_api" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="720" y="700"/>
          <mxPoint x="720" y="660"/>
          <mxPoint x="270" y="660"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════
         ARROWS — Secondary / config (dashed, grey/orange)
    ══════════════════════════════════════════════════════════════════ -->

    <!-- Secret (reviewer) → Job (env injection) -->
    <mxCell id="e7" value="ANTHROPIC_API_KEY&#xa;GITHUB_TOKEN&#xa;(env injection)"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#d79b00;strokeWidth=1.5;dashed=1;dashPattern=6 3;
                   fontColor=#d79b00;fontSize=9;
                   exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.3;entryDx=0;entryDy=0;"
            edge="1" source="sec_r" target="job" parent="1">
      <mxGeometry relative="1" as="geometry">
