                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="45" y="640" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="gh_api_sub" value="POST /pulls/{pr}/reviews&#xa;(batch inline comments)&#xa;POST /issues/{pr}/comments&#xa;(summary)"
            style="text;html=1;strokeColor=none;fillColor=none;
