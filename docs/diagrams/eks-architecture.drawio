          <mxPoint x="1500" y="620"/>
          <mxPoint x="1750" y="620"/>
          <mxPoint x="1750" y="690"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Secret (webhook) → Deployment (HMAC key) -->
    <mxCell id="e8" value="WEBHOOK_SECRET"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#d79b00;strokeWidth=1.5;dashed=1;dashPattern=6 3;
                   fontColor=#d79b00;fontSize=9;
                   exitX=0;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="sec_w" target="deploy" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- ECR → Job (image pull) -->
    <mxCell id="e9" value="imagePull&#xa;pr-reviewer:latest"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#9673a6;strokeWidth=1.5;dashed=1;dashPattern=6 3;
                   fontColor=#9673a6;fontSize=9;
                   exitX=0;exitY=0.5;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="ecr" target="job" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="1950" y="390"/>
          <mxPoint x="1950" y="700"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ECR → Deployment (webhook image pull) -->
    <mxCell id="e10" value="imagePull&#xa;webhook:latest"
            style="edgeStyle=orthogonalEdgeStyle;html=1;
                   strokeColor=#9673a6;strokeWidth=1.5;dashed=1;dashPattern=6 3;
                   fontColor=#9673a6;fontSize=9;
                   exitX=0;exitY=0.3;exitDx=0;exitDy=0;
                   entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
            edge="1" source="ecr" target="deploy_box" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="1960" y="370"/>
          <mxPoint x="1960" y="300"/>
          <mxPoint x="1260" y="300"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════
         LEGEND
    ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="legend_box" value="Legend"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#f5f5f5;strokeColor=#666666;
                   verticalAlign=top;align=center;
                   fontSize=11;fontStyle=1;"
            vertex="1" parent="1">
      <mxGeometry x="560" y="900" width="560" height="380" as="geometry"/>
    </mxCell>
    <mxCell id="leg1" value="──────▶  Primary data flow (request / response)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=middle;fontSize=10;
                   fontColor=#1565c0;spacingLeft=10;"
            vertex="1" parent="1">
      <mxGeometry x="575" y="940" width="520" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="leg2" value="- - - - -▶  Configuration injection (env vars, image pull)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=middle;fontSize=10;
                   fontColor=#d79b00;spacingLeft=10;"
            vertex="1" parent="1">
      <mxGeometry x="575" y="970" width="520" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="leg3"
            value="Colour coding:&#xa;  🟡 Yellow  →  External systems (GitHub, Anthropic)&#xa;  🔵 Blue    →  Network / routing components (ALB, Service)&#xa;  🟢 Green   →  Compute / application (Deployment, Job)&#xa;  🟠 Orange  →  Secrets and configuration&#xa;  🟣 Purple  →  Container registry (ECR)&#xa;  🔴 Red     →  Ephemeral job (born and dies with each PR event)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;
                   spacingLeft=10;"
            vertex="1" parent="1">
      <mxGeometry x="575" y="1005" width="520" height="160" as="geometry"/>
    </mxCell>
    <mxCell id="leg4"
            value="Security notes:&#xa;  • HMAC verified before any business logic executes&#xa;  • ServiceAccount scoped to batch/v1 jobs in this namespace only&#xa;  • Secrets never logged; injected as env vars into Job pods&#xa;  • Jobs auto-deleted 1 h after completion (ttlSecondsAfterFinished)"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;
                   spacingLeft=10;fontColor=#b85450;"
            vertex="1" parent="1">
      <mxGeometry x="575" y="1185" width="520" height="80" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
