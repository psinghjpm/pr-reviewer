            vertex="1" parent="1">
      <mxGeometry x="530" y="120" width="1440" height="1200" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════
         BOUNDARY: namespace pr-reviewer
    ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="ns_box" value="  namespace: pr-reviewer"
