                   fillColor=#fff2cc;strokeColor=#d6b656;
                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="45" y="420" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="ant_sub" value="claude-sonnet-4-6&#xa;5-pass agentic review loop&#xa;multi-turn tool calls"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=10;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="45" y="462" width="180" height="45" as="geometry"/>
    </mxCell>

    <!-- GitHub API -->
