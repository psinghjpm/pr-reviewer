<?xml version="1.0" encoding="UTF-8"?>
<!--
  PRGenie — EKS Architecture (draw.io / Lucidchart)
  ──────────────────────────────────────────────────
  Import into Lucidchart:  File → Import → Diagrams.net / draw.io
  Import into draw.io:     File → Import from → Device  (or drag-drop)
  Edit online:             https://app.diagrams.net
-->
<mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1"
              tooltips="1" connect="1" arrows="1" fold="1"
              page="1" pageScale="1" pageWidth="2200" pageHeight="1400"
              math="0" shadow="1">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- ══════════════════════════════════════════════════════════════
         TITLE
    ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="PRGenie — EKS Event-Driven Architecture"
            style="text;html=1;strokeColor=none;fillColor=none;align=center;
                   verticalAlign=middle;whiteSpace=wrap;rounded=0;
                   fontSize=22;fontStyle=1;fontColor=#232F3E;"
            vertex="1" parent="1">
      <mxGeometry x="500" y="20" width="1200" height="40" as="geometry"/>
    </mxCell>

    <!-- ══════════════════════════════════════════════════════════════
         BOUNDARY: External Systems
    ══════════════════════════════════════════════════════════════════ -->
    <mxCell id="ext_box" value="🌐  External Systems"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#fffde7;strokeColor=#f9a825;
                   verticalAlign=top;align=left;spacingLeft=10;
                   fontSize=13;fontStyle=1;dashed=1;dashPattern=8 4;
                   arcSize=4;"
            vertex="1" parent="1">
      <mxGeometry x="20" y="80" width="230" height="700" as="geometry"/>
    </mxCell>

    <!-- GitHub Source -->
    <mxCell id="gh_src" value="🐙  GitHub.com"
            style="rounded=1;whiteSpace=wrap;html=1;
                   fillColor=#fff2cc;strokeColor=#d6b656;
                   fontSize=12;fontStyle=1;align=center;"
            vertex="1" parent="1">
      <mxGeometry x="45" y="150" width="180" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="gh_src_sub" value="PR opened · updated · reopened&#xa;GitHub sends webhook event"
            style="text;html=1;strokeColor=none;fillColor=none;
                   align=center;verticalAlign=top;fontSize=10;whiteSpace=wrap;"
            vertex="1" parent="1">
      <mxGeometry x="45" y="192" width="180" height="35" as="geometry"/>
    </mxCell>

    <!-- Anthropic API -->
    <mxCell id="ant" value="🤖  Anthropic API"
